<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="CamStockPicker.Views.DetailPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    Title="Detail">

    <ScrollView>
        <VerticalStackLayout Padding="16" Spacing="14">

            <!-- Header: Symbol + company -->
            <Label Text="{Binding Symbol}"
                   FontAttributes="Bold"
                   FontSize="{DynamicResource AppFontSizeTitle}"
                   TextColor="{AppThemeBinding Light=#111111, Dark=#FFFFFF}" />

            <Label Text="{Binding CompanyName}"
                   TextColor="{AppThemeBinding Light=#5B6472, Dark=#AAB2C0}"
                   FontSize="{DynamicResource AppFontSize}" />

            <!-- Price -->
            <Label Text="{Binding PriceText}"
                   FontAttributes="Bold"
                   FontSize="{DynamicResource AppFontSizeBig}"
                   TextColor="{AppThemeBinding Light=#111111, Dark=#FFFFFF}" />

            <!-- Change -->
            <Label Text="{Binding ChangeText}"
                   FontSize="{DynamicResource AppFontSize}"
                   TextColor="{Binding ChangeColor}" />

            <!-- Refresh/Add -->
            <Grid ColumnDefinitions="*,*" ColumnSpacing="12" Margin="0,6,0,0">
                <Button Text="Refresh"
                        CornerRadius="12"
                        HeightRequest="50"
                        BackgroundColor="{AppThemeBinding Light=White, Dark=#2A2A2A}"
                        BorderColor="{AppThemeBinding Light=#D9DDE5, Dark=#444444}"
                        BorderWidth="1"
                        TextColor="{AppThemeBinding Light=Black, Dark=White}"
                        FontSize="{DynamicResource AppFontSize}"
                        Command="{Binding RefreshCommand}" />

                <Button Grid.Column="1"
                        Text="Add to Watchlist"
                        CornerRadius="12"
                        HeightRequest="50"
                        BackgroundColor="#2F7CF6"
                        TextColor="White"
                        FontSize="{DynamicResource AppFontSize}"
                        Command="{Binding AddToWatchlistCommand}" />
            </Grid>

            <!-- Statistics card -->
            <Frame Padding="14"
                   CornerRadius="12"
                   HasShadow="False"
                   BackgroundColor="{AppThemeBinding Light=White, Dark=#1E1E1E}"
                   BorderColor="{AppThemeBinding Light=#D9DDE5, Dark=#444444}">
                <VerticalStackLayout Spacing="10">
                    <Label Text="Statistics"
                           FontAttributes="Bold"
                           TextColor="{AppThemeBinding Light=#5B6472, Dark=#E5E7EB}"
                           FontSize="{DynamicResource AppFontSize}" />

                    <Grid ColumnDefinitions="*,Auto"
                          RowDefinitions="Auto,Auto,Auto,Auto"
                          RowSpacing="10">
                        <Label Text="Open"
                               TextColor="{AppThemeBinding Light=#5B6472, Dark=#AAB2C0}"
                               FontSize="{DynamicResource AppFontSize}" />
                        <Label Grid.Column="1"
                               Text="{Binding OpenText}"
                               FontAttributes="Bold"
                               TextColor="{AppThemeBinding Light=#111111, Dark=#FFFFFF}"
                               FontSize="{DynamicResource AppFontSize}" />

                        <Label Grid.Row="1"
                               Text="High"
                               TextColor="{AppThemeBinding Light=#5B6472, Dark=#AAB2C0}"
                               FontSize="{DynamicResource AppFontSize}" />
                        <Label Grid.Row="1"
                               Grid.Column="1"
                               Text="{Binding HighText}"
                               FontAttributes="Bold"
                               TextColor="{AppThemeBinding Light=#111111, Dark=#FFFFFF}"
                               FontSize="{DynamicResource AppFontSize}" />

                        <Label Grid.Row="2"
                               Text="Low"
                               TextColor="{AppThemeBinding Light=#5B6472, Dark=#AAB2C0}"
                               FontSize="{DynamicResource AppFontSize}" />
                        <Label Grid.Row="2"
                               Grid.Column="1"
                               Text="{Binding LowText}"
                               FontAttributes="Bold"
                               TextColor="{AppThemeBinding Light=#111111, Dark=#FFFFFF}"
                               FontSize="{DynamicResource AppFontSize}" />

                        <Label Grid.Row="3"
                               Text="Prev Close"
                               TextColor="{AppThemeBinding Light=#5B6472, Dark=#AAB2C0}"
                               FontSize="{DynamicResource AppFontSize}" />
                        <Label Grid.Row="3"
                               Grid.Column="1"
                               Text="{Binding PrevCloseText}"
                               FontAttributes="Bold"
                               TextColor="{AppThemeBinding Light=#111111, Dark=#FFFFFF}"
                               FontSize="{DynamicResource AppFontSize}" />
                    </Grid>
                </VerticalStackLayout>
            </Frame>

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>