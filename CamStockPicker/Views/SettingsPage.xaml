<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="CamStockPicker.Views.SettingsPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    Title="Settings">

    <ScrollView>
        <VerticalStackLayout Padding="16" Spacing="14">

            <Label Text="Settings" FontSize="28" FontAttributes="Bold" />

            <!-- Appearance card -->
            <Frame Padding="14" CornerRadius="12" HasShadow="False" BorderColor="#D9DDE5">
                <VerticalStackLayout Spacing="12">
                    <Label Text="Appearance" FontAttributes="Bold" TextColor="#5B6472" />

                    <Grid ColumnDefinitions="*,Auto">
                        <Label Text="Dark Mode" VerticalOptions="Center" />
                        <Switch Grid.Column="1"
                                IsToggled="{Binding IsDarkMode}" />
                    </Grid>

                    <Label Text="Font Size" TextColor="#5B6472" />

                    <Grid ColumnDefinitions="*,*,*" ColumnSpacing="10">
                        <Button Text="S"
                                CornerRadius="12"
                                HeightRequest="48"
                                Command="{Binding SetFontSmallCommand}"
                                BackgroundColor="{Binding FontSmallBg}"
                                TextColor="{Binding FontSmallFg}"
                                BorderColor="#D9DDE5"
                                BorderWidth="1" />
                        <Button Grid.Column="1" Text="M"
                                CornerRadius="12"
                                HeightRequest="48"
                                Command="{Binding SetFontMediumCommand}"
                                BackgroundColor="{Binding FontMediumBg}"
                                TextColor="{Binding FontMediumFg}"
                                BorderColor="#D9DDE5"
                                BorderWidth="1" />
                        <Button Grid.Column="2" Text="L"
                                CornerRadius="12"
                                HeightRequest="48"
                                Command="{Binding SetFontLargeCommand}"
                                BackgroundColor="{Binding FontLargeBg}"
                                TextColor="{Binding FontLargeFg}"
                                BorderColor="#D9DDE5"
                                BorderWidth="1" />
                    </Grid>
                </VerticalStackLayout>
            </Frame>

            <!-- Quote display card -->
            <Frame Padding="14" CornerRadius="12" HasShadow="False" BorderColor="#D9DDE5">
                <VerticalStackLayout Spacing="12">
                    <Label Text="Quote Display" FontAttributes="Bold" TextColor="#5B6472" />
                    <Label Text="Change Display Mode" />

                    <Grid ColumnDefinitions="*,*" ColumnSpacing="10">
                        <Button Text="$"
                                CornerRadius="12"
                                HeightRequest="48"
                                Command="{Binding SetChangeDollarsCommand}"
                                BackgroundColor="{Binding DollarsBg}"
                                TextColor="{Binding DollarsFg}"
                                BorderColor="#D9DDE5"
                                BorderWidth="1" />
                        <Button Grid.Column="1" Text="%"
                                CornerRadius="12"
                                HeightRequest="48"
                                Command="{Binding SetChangePercentCommand}"
                                BackgroundColor="{Binding PercentBg}"
                                TextColor="{Binding PercentFg}"
                                BorderColor="#D9DDE5"
                                BorderWidth="1" />
                    </Grid>

                    <Label Text="Choose how price changes are displayed on the Detail screen"
                           FontSize="12"
                           TextColor="#8A93A3" />
                </VerticalStackLayout>
            </Frame>

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>