<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="CamStockPicker.Views.WatchlistPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    Title="Watchlist">

    <Grid Padding="16" RowDefinitions="Auto,*">
        <Label Text="Watchlist" FontSize="28" FontAttributes="Bold" />

        <!-- Empty state -->
        <VerticalStackLayout Grid.Row="1"
                             VerticalOptions="Center"
                             HorizontalOptions="Center"
                             Spacing="10">
            <Label Text="☆" FontSize="72" TextColor="#C7CDD6" HorizontalTextAlignment="Center" />
            <Label Text="No favourites yet."
                   FontSize="16"
                   TextColor="#5B6472"
                   HorizontalTextAlignment="Center" />
            <Label Text="Add from Detail screen."
                   FontSize="14"
                   TextColor="#8A93A3"
                   HorizontalTextAlignment="Center" />
        </VerticalStackLayout>
    </Grid>
</ContentPage>