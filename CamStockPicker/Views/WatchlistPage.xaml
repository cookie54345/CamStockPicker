<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="CamStockPicker.Views.WatchlistPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    Title="Watchlist">

	<Grid Padding="16" RowDefinitions="Auto,*">
		<!-- Main Title -->
		<Label Text="Watchlist"
               FontAttributes="Bold"
               FontSize="{DynamicResource AppFontSizeTitle}" />

		<VerticalStackLayout Grid.Row="1"
                             VerticalOptions="Center"
                             HorizontalOptions="Center"
                             Spacing="10">
			<VerticalStackLayout.Triggers>
				<DataTrigger TargetType="VerticalStackLayout"
                             Binding="{Binding Items.Count}"
                             Value="0">
					<Setter Property="IsVisible" Value="True" />
				</DataTrigger>
			</VerticalStackLayout.Triggers>

			<VerticalStackLayout.IsVisible>False</VerticalStackLayout.IsVisible>

			<Label Text="☆"
                   FontSize="{DynamicResource AppFontSizeBig}"
                   TextColor="#C7CDD6"
                   HorizontalTextAlignment="Center" />
			<Label Text="No favourites yet."
                   FontSize="{DynamicResource AppFontSize}"
                   TextColor="#5B6472"
                   HorizontalTextAlignment="Center" />
			<Label Text="Add from Detail screen."
                   FontSize="{DynamicResource AppFontSize}"
                   TextColor="#8A93A3"
                   HorizontalTextAlignment="Center" />
		</VerticalStackLayout>

		<!-- Active List View -->
		<CollectionView Grid.Row="1"
                        ItemsSource="{Binding Items}"
                        SelectionMode="Single"
                        SelectionChangedCommand="{Binding OpenDetailCommand}"
                        SelectionChangedCommandParameter="{Binding CurrentSelection[0], Source={RelativeSource Self}}">
			<CollectionView.Triggers>
				<DataTrigger TargetType="CollectionView"
                             Binding="{Binding Items.Count}"
                             Value="0">
					<Setter Property="IsVisible" Value="False" />
				</DataTrigger>
			</CollectionView.Triggers>

			<CollectionView.ItemTemplate>
				<DataTemplate>
					<Frame Padding="14"
                           CornerRadius="12"
                           HasShadow="True"
                           BorderColor="{AppThemeBinding Light=#D9DDE5, Dark=#2C2C2C}"
                           BackgroundColor="{AppThemeBinding Light=#FFFFFF, Dark=#1E1E1E}"
                           Margin="0,0,0,10">
						<Frame.Shadow>
							<Shadow Brush="#000000" Opacity="{AppThemeBinding Light=0.06, Dark=0.2}" Radius="8" Offset="0,2"/>
						</Frame.Shadow>

						<Grid ColumnDefinitions="*,Auto" RowDefinitions="Auto,Auto">
							<Label Text="{Binding Symbol}"
                                   FontAttributes="Bold"
                                   FontSize="{DynamicResource AppFontSize}" />
							<Label Grid.Row="1"
                                   Text="{Binding Name}"
                                   TextColor="#5B6472"
                                   FontSize="{DynamicResource AppFontSize}" />
							<Label Grid.Column="1"
                                   Grid.RowSpan="2"
                                   Text="›"
                                   FontSize="{DynamicResource AppFontSizeTitle}"
                                   TextColor="#9AA3AF"
                                   VerticalOptions="Center" />
						</Grid>
					</Frame>
				</DataTemplate>
			</CollectionView.ItemTemplate>
		</CollectionView>

	</Grid>
</ContentPage>